      display:grid;
      place-items:center;
      flex:0 0 auto;
    }

    .person-photo::after{content:"N";color:var(--accent-contrast);font-weight:800;font-size:2rem;}
    .contact-person strong{display:block;color:var(--ink);font-weight:800;}
    .contact-person span{display:block;color:var(--muted);font-weight:600;margin-top:3px;}

    label{display:block;font-weight:800;margin-bottom:7px;color:var(--ink);}

    input,select,textarea{
      width:100%;
      border:1px solid #b9c0bb;
      border-radius:16px;
      padding:14px 15px;
      font:inherit;
      color:var(--ink);
      background:var(--white);
      font-weight:600;
    }

    input::placeholder,textarea::placeholder{color:#66736c;}

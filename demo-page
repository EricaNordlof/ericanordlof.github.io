        }finally{
          if(submitButton){
            submitButton.disabled = false;
            submitButton.textContent = originalButtonText;
          }
        }
      });
    }

      if(galleryPrev){galleryPrev.addEventListener("click", () => scrollGallery(-1));}
      if(galleryNext){galleryNext.addEventListener("click", () => scrollGallery(1));}

      if(imageStrip){
        let isDown = false;
        let startX = 0;
        let scrollLeft = 0;

        imageStrip.addEventListener("mousedown", e => {
          isDown = true;
          startX = e.pageX - imageStrip.offsetLeft;
          scrollLeft = imageStrip.scrollLeft;
        });

        imageStrip.addEventListener("mouseleave", () => {isDown = false;});
        imageStrip.addEventListener("mouseup", () => {isDown = false;});
        imageStrip.addEventListener("mousemove", e => {
          if(!isDown) return;
          e.preventDefault();
          const x = e.pageX - imageStrip.offsetLeft;
          const walk = (x - startX) * 1.2;
          imageStrip.scrollLeft = scrollLeft - walk;
        });
        imageStrip.addEventListener("scroll", updateGalleryButtons);
      }

      window.addEventListener("scroll", updateFixedHeader, {passive:true});
      window.addEventListener("resize", () => {updateFixedHeader();updateGalleryButtons();});
      window.addEventListener("load", () => {updateFixedHeader();updateGalleryButtons();});

      const savedPalette = localStorage.getItem(STORAGE.palette) || "classic";
      if(paletteSelect) paletteSelect.value = savedPalette;

      if(savedPalette === "custom"){
        applyPalette({
          bg:localStorage.getItem(STORAGE.bgHex) || "#EFE8DC",
          paper:localStorage.getItem(STORAGE.paperHex) || "#FFFAF3",
          ink:localStorage.getItem(STORAGE.inkHex) || "#16211D",
          accent:localStorage.getItem(STORAGE.accentHex) || "#16382F"
        });
      }else{
        applySelectedPalette(savedPalette);
      }

      const savedStylePreset = localStorage.getItem(STORAGE.stylePreset);
      if(savedStylePreset && STYLE_PRESETS[savedStylePreset]){
        applyStylePreset(savedStylePreset, false);
      }else{
        if(stylePresetSelect) stylePresetSelect.value = "";
        applyFontStyle(localStorage.getItem(STORAGE.font) || "inter");
      }

      setLargeText(localStorage.getItem(STORAGE.text) === "large");
      setHighContrast(localStorage.getItem(STORAGE.contrast) === "high");
      updateFixedHeader();
      updateGalleryButtons();
    })();
  </script>
</body>
</html>

      function getSlideWidth(){
        const firstSlide = imageStrip ? imageStrip.querySelector(".photo-slide") : null;
        if(!firstSlide) return 320;
        const styles = window.getComputedStyle(imageStrip);
        const gap = parseInt(styles.columnGap || styles.gap || 18, 10) || 18;
        return firstSlide.getBoundingClientRect().width + gap;
      }

      function updateGalleryButtons(){
        if(!imageStrip || !galleryPrev || !galleryNext) return;
        const maxScroll = imageStrip.scrollWidth - imageStrip.clientWidth;
        galleryPrev.disabled = imageStrip.scrollLeft <= 8;
        galleryNext.disabled = imageStrip.scrollLeft >= maxScroll - 8;
      }

      function scrollGallery(direction){
        if(!imageStrip) return;
        imageStrip.scrollBy({left:getSlideWidth() * direction, behavior:"smooth"});
      }

      function editableElements(){
        return Array.from(document.querySelectorAll([
          "main h1",
          "main h2",
          "main h3",
          "main p",
          "main li",
          "main a.btn",
          "main .badge",
          "main .fact strong",
          "main .eyebrow",
          ".logo-text strong",
          ".logo-text span",
          ".topbar-title",
          "footer .footer-copy"
        ].join(", "))).filter(el => {
          if(el.closest("form")) return false;
          if(el.closest(".design-panel")) return false;
          if(el.closest("nav")) return false;
          if(el.closest(".text-editor-modal")) return false;
          return true;
        });
      }

      function saveEditedHtmlToBrowser(){
        const main = document.getElementById("main");
        const footer = document.querySelector("footer");
        if(!main || !footer) return;
        localStorage.setItem(STORAGE_EDITED_HTML, JSON.stringify({main:main.innerHTML, footer:footer.innerHTML}));
      }

      function loadEditedHtmlFromBrowser(){
        try{
          const saved = localStorage.getItem(STORAGE_EDITED_HTML);
          if(!saved) return;
          const data = JSON.parse(saved);
          const main = document.getElementById("main");
          const footer = document.querySelector("footer");
          if(data.main && main) main.innerHTML = data.main;
          if(data.footer && footer) footer.innerHTML = data.footer;
        }catch(error){
          console.warn("Kunde inte läsa sparad text.", error);
        }
      }

      function setEditMode(isEditing){
        body.classList.toggle("edit-mode", isEditing);
        editableElements().forEach(el => {
          if(isEditing){
            el.dataset.editableText = "true";
            el.setAttribute("tabindex", "0");
            el.setAttribute("role", "button");
            el.setAttribute("aria-label", "Klicka för att ändra text");
          }else{
            delete el.dataset.editableText;
            el.removeAttribute("tabindex");
            if(el.getAttribute("role") === "button") el.removeAttribute("role");
            if(el.getAttribute("aria-label") === "Klicka för att ändra text") el.removeAttribute("aria-label");
          }
        });
        if(editToggle){
          editToggle.textContent = isEditing ? "Stäng textredigering" : "Redigera text";
          editToggle.setAttribute("aria-pressed", isEditing ? "true" : "false");
        }
      }

      function openTextEditor(element){
        if(!element || !modal || !textInput) return;
        activeElement = element;
        textInput.value = element.innerText.trim();
        modal.classList.add("open");
        modal.setAttribute("aria-hidden", "false");
        setTimeout(() => {
          textInput.focus();
          textInput.setSelectionRange(textInput.value.length, textInput.value.length);
        }, 80);
      }

      function closeTextEditor(){
        if(!modal) return;
        modal.classList.remove("open");
        modal.setAttribute("aria-hidden", "true");
        activeElement = null;
      }

      function saveTextEditorValue(){
        if(!activeElement || !textInput) return;
        activeElement.innerText = textInput.value.trim();
        saveEditedHtmlToBrowser();
        closeTextEditor();
        updateFixedHeader();
      }

      function cleanForDownload(doc){
        doc.querySelectorAll("[data-editable-text], [contenteditable], [tabindex]").forEach(el => {
          el.removeAttribute("data-editable-text");
          el.removeAttribute("contenteditable");
          el.removeAttribute("tabindex");
          if(el.getAttribute("role") === "button") el.removeAttribute("role");
          if(el.getAttribute("aria-label") === "Klicka för att ändra text") el.removeAttribute("aria-label");
        });
        doc.querySelectorAll(".text-editor-modal").forEach(el => el.remove());
        const bodyClone = doc.querySelector("body");
        if(bodyClone){
          bodyClone.classList.remove("edit-mode", "header-fixed");
        }
        const editBtn = doc.querySelector("#editToggle");
        if(editBtn){
          editBtn.textContent = "Redigera text";
          editBtn.setAttribute("aria-pressed", "false");
        }
      }

      function downloadEditedHtml(){
        saveEditedHtmlToBrowser();
        setEditMode(false);
        const clone = document.documentElement.cloneNode(true);
        cleanForDownload(clone);
        const html = "<!doctype html>\n" + clone.outerHTML;
        const blob = new Blob([html], {type:"text/html;charset=utf-8"});
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = url;
        link.download = "andrad-demo-hemsida-" + new Date().toISOString().slice(0,10) + ".html";
        document.body.appendChild(link);
        link.click();
        link.remove();
        URL.revokeObjectURL(url);
      }


      function clampNumber(value, min, max, fallback){
        const number = Number(value);
        if(Number.isNaN(number)) return fallback;
        return Math.min(max, Math.max(min, number));
      }

      function rgbToHex(r,g,b){
        return "#" + [r,g,b].map(value => {
          const hex = Math.max(0, Math.min(255, Math.round(value))).toString(16);
          return hex.length === 1 ? "0" + hex : hex;
        }).join("").toUpperCase();
      }

      function normalizeHex(value, fallback){
        const cleaned = String(value || "").trim();
        if(/^#[0-9A-Fa-f]{6}$/.test(cleaned)) return cleaned.toUpperCase();
        if(/^[0-9A-Fa-f]{6}$/.test(cleaned)) return ("#" + cleaned).toUpperCase();
        return fallback.toUpperCase();
      }

      function hexToRgb(hex){
        const safe = normalizeHex(hex, "#000000").replace("#", "");
        return {r:parseInt(safe.slice(0,2),16),g:parseInt(safe.slice(2,4),16),b:parseInt(safe.slice(4,6),16)};
      }

      function mixHex(hex1, hex2, amount){
        const a = hexToRgb(hex1);
        const b = hexToRgb(hex2);
        const t = Math.max(0, Math.min(1, amount));
        return rgbToHex(a.r + (b.r - a.r) * t, a.g + (b.g - a.g) * t, a.b + (b.b - a.b) * t);
      }

      function getBrightness(hex){
        const rgb = hexToRgb(hex);
        return (rgb.r * 299 + rgb.g * 587 + rgb.b * 114) / 1000;
      }

      function getContrastText(hex){return getBrightness(hex) > 150 ? "#111111" : "#FFFFFF";}
      function getReadableMuted(ink){return getBrightness(ink) > 150 ? mixHex(ink, "#000000", .28) : mixHex(ink, "#FFFFFF", .32);}
      function hexToRgba(hex, alpha){
        const rgb = hexToRgb(hex);
        return `rgba(${rgb.r}, ${rgb.g}, ${rgb.b}, ${alpha})`;
      }

      function hslToHex(h,s,l){
        h = clampNumber(h,0,360,0);
        s = clampNumber(s,0,100,0) / 100;
        l = clampNumber(l,0,100,50) / 100;
        const c = (1 - Math.abs(2 * l - 1)) * s;
        const x = c * (1 - Math.abs((h / 60) % 2 - 1));
        const m = l - c / 2;
        let r = 0, g = 0, b = 0;
        if(h < 60){r = c; g = x; b = 0;}
        else if(h < 120){r = x; g = c; b = 0;}
        else if(h < 180){r = 0; g = c; b = x;}
        else if(h < 240){r = 0; g = x; b = c;}
        else if(h < 300){r = x; g = 0; b = c;}
        else{r = c; g = 0; b = x;}
        return rgbToHex((r + m) * 255, (g + m) * 255, (b + m) * 255);
      }

      function hexToHsl(hex){
        const rgb = hexToRgb(hex);
        const r = rgb.r / 255;
        const g = rgb.g / 255;
        const b = rgb.b / 255;
        const max = Math.max(r,g,b);
        const min = Math.min(r,g,b);
        let h = 0;
        let s = 0;
        const l = (max + min) / 2;
        if(max !== min){
          const d = max - min;
          s = l > .5 ? d / (2 - max - min) : d / (max + min);
          switch(max){
            case r: h = (g - b) / d + (g < b ? 6 : 0); break;
            case g: h = (b - r) / d + 2; break;
            default: h = (r - g) / d + 4;
          }
          h = h * 60;
        }
        return {h:Math.round(h),s:Math.round(s * 100),l:Math.round(l * 100)};
      }

      function setVar(name, value){body.style.setProperty(name, value);}

      function syncInputs(values){
        const bg = normalizeHex(values.bg, "#EFE8DC");
        const paper = normalizeHex(values.paper, "#FFFAF3");
        const ink = normalizeHex(values.ink, "#16211D");
        const accent = normalizeHex(values.accent, "#16382F");
        if(bgHex) bgHex.value = bg;
        if(paperHex) paperHex.value = paper;
        if(inkHex) inkHex.value = ink;
        if(accentHex) accentHex.value = accent;
        if(bgPicker) bgPicker.value = bg;
        if(paperPicker) paperPicker.value = paper;
        if(inkPicker) inkPicker.value = ink;
        if(accentPicker) accentPicker.value = accent;
        const bgHsl = hexToHsl(bg);
        const accentHsl = hexToHsl(accent);
        if(bgHue) bgHue.value = bgHsl.h;
        if(bgLight) bgLight.value = bgHsl.l;
        if(accentHue) accentHue.value = accentHsl.h;
      }

      function applyPalette(values, save = true){
        const bg = normalizeHex(values.bg, "#EFE8DC");
        const paper = normalizeHex(values.paper, "#FFFAF3");
        const ink = normalizeHex(values.ink, "#16211D");
        const accent = normalizeHex(values.accent, "#16382F");
        const bgIsDark = getBrightness(bg) < 120;
        const accentContrast = getContrastText(accent);
        const muted = getReadableMuted(ink);
        const bg2 = mixHex(bg, bgIsDark ? "#FFFFFF" : "#000000", .05);
        const line = mixHex(paper, ink, .15);
        const lineDark = mixHex(paper, ink, .28);
        const accent2 = mixHex(accent, accentContrast === "#FFFFFF" ? "#FFFFFF" : "#000000", .14);
        const accentSoft = mixHex(paper, accent, .16);
        const gold = mixHex(accent, "#D9AA67", .45);
        const gold2 = mixHex(accent, "#FFD18A", .35);

        setVar("--bg", bg);
        setVar("--bg-2", bg2);
        setVar("--paper", paper);
        setVar("--white", paper);
        setVar("--ink", ink);
        setVar("--muted", muted);
        setVar("--line", line);
        setVar("--line-dark", lineDark);
        setVar("--bg-glow-1", hexToRgba(mixHex(bg, accent, .16), bgIsDark ? .20 : .24));
        setVar("--accent", accent);
        setVar("--accent-2", accent2);
        setVar("--accent-soft", accentSoft);
        setVar("--accent-contrast", accentContrast);
        setVar("--gold", gold);
        setVar("--gold-2", gold2);
        setVar("--focus", accent);
        setVar("--topbar", mixHex(accent, "#000000", .35));
        setVar("--contact-bg", mixHex(accent, "#000000", .55));
        setVar("--footer-bg", mixHex(accent, "#000000", .68));
        setVar("--shadow", bgIsDark ? "0 28px 90px rgba(0,0,0,.34)" : "0 28px 90px rgba(20,32,27,.15)");
        setVar("--shadow-soft", bgIsDark ? "0 18px 50px rgba(0,0,0,.24)" : "0 18px 50px rgba(20,32,27,.09)");

        if(bgDot) bgDot.style.background = bg;
        if(lightDot) lightDot.style.background = paper;
        if(accentDot) accentDot.style.background = accent;
        syncInputs({bg, paper, ink, accent});

        if(save){
          localStorage.setItem(STORAGE.bgHex, bg);
          localStorage.setItem(STORAGE.paperHex, paper);
          localStorage.setItem(STORAGE.inkHex, ink);
          localStorage.setItem(STORAGE.accentHex, accent);
        }

        const metaTheme = document.querySelector('meta[name="theme-color"]');
        if(metaTheme) metaTheme.setAttribute("content", mixHex(accent, "#000000", .35));
        updateFixedHeader();
      }

      function applySelectedPalette(key){
        if(key === "custom"){
          applyPalette({
            bg:localStorage.getItem(STORAGE.bgHex) || "#EFE8DC",
            paper:localStorage.getItem(STORAGE.paperHex) || "#FFFAF3",
            ink:localStorage.getItem(STORAGE.inkHex) || "#16211D",
            accent:localStorage.getItem(STORAGE.accentHex) || "#16382F"
          });
          localStorage.setItem(STORAGE.palette, "custom");
          return;
        }
        const palette = PALETTES[key] || PALETTES.classic;
        if(paletteSelect) paletteSelect.value = key;
        localStorage.setItem(STORAGE.palette, key);
        applyPalette(palette);
      }

      function applySliderPalette(){
        localStorage.removeItem(STORAGE.stylePreset);
        if(stylePresetSelect) stylePresetSelect.value = "";
        const bg = clampNumber(bgHue?.value, 0, 360, 38);
        const light = clampNumber(bgLight?.value, 0, 100, 92);
        const accent = clampNumber(accentHue?.value, 0, 360, 157);
        const isDark = light < 42;
        const values = {
          bg:hslToHex(bg, 45, light),
          paper:hslToHex(bg, 35, isDark ? Math.min(light + 6, 28) : Math.min(light + 5, 99)),
          ink:hslToHex(bg, 22, isDark ? 96 : 12),
          accent:hslToHex(accent, 58, isDark ? 58 : 24)
        };
        if(paletteSelect) paletteSelect.value = "custom";
        localStorage.setItem(STORAGE.palette, "custom");
        localStorage.setItem(STORAGE.bgHue, String(bg));
        localStorage.setItem(STORAGE.bgLight, String(light));
        localStorage.setItem(STORAGE.accentHue, String(accent));
        applyPalette(values);
      }

      function applyManualHexChange(){
        localStorage.removeItem(STORAGE.stylePreset);
        if(stylePresetSelect) stylePresetSelect.value = "";
        if(paletteSelect) paletteSelect.value = "custom";
        localStorage.setItem(STORAGE.palette, "custom");
        applyPalette({
          bg:bgHex?.value || bgPicker?.value || "#EFE8DC",
          paper:paperHex?.value || paperPicker?.value || "#FFFAF3",
          ink:inkHex?.value || inkPicker?.value || "#16211D",
          accent:accentHex?.value || accentPicker?.value || "#16382F"
        });
      }

      function applyStylePreset(presetKey, save = true){
        const preset = STYLE_PRESETS[presetKey];
        if(!preset) return;
        applySelectedPalette(preset.palette);
        applyFontStyle(preset.font);
        if(stylePresetSelect) stylePresetSelect.value = presetKey;
        if(save) localStorage.setItem(STORAGE.stylePreset, presetKey);
      }

      function applyFontStyle(fontKey){
        const safeKey = FONT_MAP[fontKey] ? fontKey : "inter";
        const selectedFont = FONT_MAP[safeKey];
        body.style.setProperty("--font-main", selectedFont.main);
        body.style.setProperty("--font-heading", selectedFont.heading);
        if(fontSelect) fontSelect.value = safeKey;
        localStorage.setItem(STORAGE.font, safeKey);
        updateFixedHeader();

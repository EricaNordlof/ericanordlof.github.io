<!doctype html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />

  <title>Gratis demo av ny hemsida | Nordlöf Nordic</title>
  <meta name="description" content="Beställ en gratis demo av en ny hemsida. Skicka företagsberättelse, bilder, material och önskemål – Nordlöf Nordic bygger ett tydligt sidförslag först." />
  <meta name="robots" content="noindex,nofollow" />
  <meta name="theme-color" content="#173128" />
  <meta name="author" content="Nordlöf Nordic" />
  <meta property="og:title" content="Gratis demo av ny hemsida | Nordlöf Nordic" />
  <meta property="og:description" content="Skicka material och önskemål. Få ett konkret sidförslag innan du bestämmer dig." />
  <meta property="og:type" content="website" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Abril+Fatface&family=Bebas+Neue&family=Cormorant+Garamond:wght@400;600;700&family=DM+Sans:wght@400;600;700;900&family=Inter:wght@400;600;700;800;900&family=Lato:wght@400;700;900&family=Lexend:wght@400;600;700;900&family=Lora:wght@400;600;700&family=Manrope:wght@400;600;700;900&family=Merriweather:wght@400;700;900&family=Montserrat:wght@400;600;700;900&family=Nunito:wght@400;600;700;900&family=Open+Sans:wght@400;600;700;800&family=Oswald:wght@400;600;700&family=Playfair+Display:wght@400;600;700;900&family=Poppins:wght@400;600;700;900&family=Quicksand:wght@400;600;700&family=Raleway:wght@400;600;700;900&family=Roboto:wght@400;700;900&family=Roboto+Slab:wght@400;600;700;900&family=Rubik:wght@400;600;700;900&family=Source+Sans+3:wght@400;600;700;900&family=Space+Grotesk:wght@400;600;700&family=Work+Sans:wght@400;600;700;900&display=swap" rel="stylesheet" />

  <style>
    :root{
      --bg:#efe8dc;
      --bg-2:#f8f3eb;
      --paper:#fffaf3;
      --white:#ffffff;
      --ink:#16211d;
      --muted:#53615a;
      --accent:#16382f;
      --accent-2:#24594b;
      --accent-soft:#dfeae4;
      --accent-contrast:#ffffff;
      --gold:#b98542;
      --gold-2:#d9aa67;
      --line:#ddd1c0;
      --line-dark:#c8b9a4;
      --shadow:0 28px 90px rgba(20,32,27,.16);
      --shadow-soft:0 18px 50px rgba(20,32,27,.10);
      --topbar:#173128;
      --contact-bg:#151f1b;
      --footer-bg:#0f1714;
      --bg-glow-1:rgba(185,133,66,.22);
      --focus:#b45309;
      --radius:28px;
      --max:1180px;
      --header-offset:0px;
      --font-main:"Inter", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      --font-heading:"Inter", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    *{box-sizing:border-box;}

    html{
      scroll-behavior:smooth;
      text-size-adjust:100%;
      font-size:16px;
      max-width:100%;
      overflow-x:hidden;
    }

    html.large-text{font-size:112%;}

    body{
      margin:0;
      font-family:var(--font-main);
      color:var(--ink);
      background:
        radial-gradient(circle at top left, var(--bg-glow-1), transparent 34rem),
        radial-gradient(circle at top right, color-mix(in srgb, var(--accent) 16%, transparent), transparent 36rem),
        linear-gradient(180deg, var(--bg) 0%, var(--bg-2) 100%);
      line-height:1.6;
      overflow-x:hidden;
      -webkit-font-smoothing:antialiased;
      -moz-osx-font-smoothing:grayscale;
      text-rendering:optimizeLegibility;
    }

    a{color:inherit;}
    img{display:block;max-width:100%;}

    h1,h2,h3,p,li,a,button,label,input,select,textarea,span,strong{
      overflow-wrap:break-word;
      word-break:normal;
      hyphens:auto;
      text-shadow:none;
    }

    .btn,.menu-btn,.design-toggle,.pill,.badge,.eyebrow,.fact span,.fact strong,.logo-text strong,.logo-text span{
      overflow-wrap:normal;
      word-break:normal;
      hyphens:none;
    }

    :focus-visible{
      outline:4px solid var(--focus);
      outline-offset:4px;
      border-radius:10px;
    }

    .skip-link{
      position:absolute;
      left:12px;
      top:-90px;
      background:#fff;
      color:#000;
      padding:12px 16px;
      border-radius:999px;
      z-index:1200;
      font-weight:800;
      transition:.2s ease;
    }

    .skip-link:focus{top:12px;}

    .topbar{
      background:var(--topbar);
      color:#f6efe5;
      border-bottom:1px solid rgba(255,255,255,.10);
      position:relative;
      z-index:10;
    }

    .topbar-inner{
      max-width:var(--max);
      margin:auto;
      padding:10px 18px;
      display:flex;
      gap:12px;
      align-items:center;
      justify-content:space-between;
      flex-wrap:wrap;
      font-weight:700;
    }

    .topbar-title{font-size:.92rem;}

    .language-pills{
      display:flex;
      align-items:center;
      gap:7px;
      flex-wrap:wrap;
      color:#fff;
      font-weight:800;
    }

    .language-pills span{font-size:.86rem;opacity:.9;}

    .pill{
      border:1px solid rgba(255,255,255,.28);
      background:rgba(255,255,255,.10);
      color:#fff;
      border-radius:999px;
      padding:8px 11px;
      font-weight:800;
      font-size:.86rem;
      cursor:default;
      font-family:var(--font-main);
    }

    .pill.active{background:#fff;color:#111827;}
    .pill.ghost{opacity:.72;}

    .design-panel{
      width:100%;
      max-width:var(--max);
      margin:0 auto;
      padding:0 18px 14px;
    }

    .edit-actions{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
    }

    .design-toggle{
      border:1px solid rgba(255,255,255,.24);
      color:#fff;
      background:rgba(255,255,255,.10);
      border-radius:999px;
      padding:10px 14px;
      cursor:pointer;
      font-weight:800;
      font-family:var(--font-main);
      min-height:44px;
    }

    .design-toggle:hover{background:#fff;color:#111827;}

    .design-tools{
      display:none;
      grid-template-columns:repeat(4, minmax(160px, 1fr));
      gap:10px;
      margin-top:12px;
      padding:12px;
      border:1px solid rgba(255,255,255,.18);
      background:rgba(255,255,255,.07);
      border-radius:22px;
    }

    .design-tools.open{display:grid;}

    .tool-field{
      display:grid;
      gap:6px;
      color:#fff;
      font-weight:800;
      font-size:.82rem;
      min-width:0;
    }

    .tool-field select,
    .tool-field input[type="text"]{
      width:100%;
      min-height:42px;
      border:1px solid rgba(255,255,255,.30);
      border-radius:14px;
      padding:10px 12px;
      font:inherit;
      font-weight:700;
      color:#111827;
      background:#fff;
    }

    .tool-field input[type="text"]{
      font-family:ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
      text-transform:uppercase;
    }

    .range-control{
      display:grid;
      grid-template-columns:minmax(0,1fr) 28px;
      gap:8px;
      align-items:center;
    }

    .range-control input[type="range"]{
      width:100%;
      height:8px;
      border-radius:999px;
      appearance:none;
      -webkit-appearance:none;
      background:linear-gradient(90deg,hsl(0 80% 55%),hsl(45 80% 55%),hsl(90 80% 45%),hsl(150 80% 42%),hsl(210 80% 55%),hsl(270 80% 58%),hsl(330 80% 55%),hsl(360 80% 55%));
      cursor:pointer;
    }

    #bgLight{background:linear-gradient(90deg,#000,#777,#fff);}

    .range-control input[type="range"]::-webkit-slider-thumb{
      appearance:none;
      -webkit-appearance:none;
      width:20px;
      height:20px;
      border-radius:999px;
      background:#fff;
      border:3px solid rgba(0,0,0,.35);
      box-shadow:0 6px 18px rgba(0,0,0,.28);
    }

    .range-control input[type="range"]::-moz-range-thumb{
      width:20px;
      height:20px;
      border-radius:999px;
      background:#fff;
      border:3px solid rgba(0,0,0,.35);
      box-shadow:0 6px 18px rgba(0,0,0,.28);
    }

    .color-line{
      display:grid;
      grid-template-columns:1fr 42px;
      gap:8px;
      align-items:end;
    }

    .color-line input[type="color"]{
      width:42px;
      height:42px;
      min-height:42px;
      padding:0;
      border:2px solid rgba(255,255,255,.75);
      border-radius:12px;
      background:transparent;
      cursor:pointer;
    }

    .color-dot{
      width:22px;
      height:22px;
      border-radius:999px;
      border:2px solid rgba(255,255,255,.82);
      background:#fff;
      box-shadow:0 5px 14px rgba(0,0,0,.22);
    }

    header{
      position:relative;
      z-index:100;
      background:color-mix(in srgb, var(--paper) 94%, transparent);
      backdrop-filter:blur(18px);
      -webkit-backdrop-filter:blur(18px);
      border-bottom:1px solid color-mix(in srgb, var(--ink) 10%, transparent);
      box-shadow:0 12px 34px rgba(20,32,27,.08);
    }

    body.header-fixed header{
      position:fixed;
      top:0;
      left:0;
      right:0;
      z-index:999;
    }

    body.header-fixed main{padding-top:var(--header-offset);}

    .nav{
      max-width:var(--max);
      margin:auto;
      padding:15px 18px;
      min-height:80px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:18px;
      position:relative;
    }

    .logo{
      display:flex;
      align-items:center;
      gap:12px;
      text-decoration:none;
      min-width:0;
      flex:1 1 auto;
    }

    .logo-mark{
      width:46px;
      height:46px;
      border-radius:16px;
      background:linear-gradient(135deg, var(--accent), var(--accent-2));
      color:var(--accent-contrast);
      display:grid;
      place-items:center;
      font-weight:800;
      letter-spacing:-.05em;
      box-shadow:0 15px 32px color-mix(in srgb, var(--accent) 22%, transparent);
      flex:0 0 auto;
    }

    .logo-text{min-width:0;}

    .logo-text strong{
      display:block;
      font-size:1.05rem;
      letter-spacing:-.02em;
      line-height:1.1;
      color:var(--ink);
      font-weight:800;
    }

    .logo-text span{
      display:block;
      font-size:.82rem;
      color:var(--muted);
      line-height:1.25;
      font-weight:600;
    }

    #siteNav{display:none !important;}

    #siteNav.open{
      display:block !important;
      position:absolute;
      top:calc(100% + 12px);
      right:18px;
      width:min(390px, calc(100vw - 36px));
      background:var(--paper);
      border:1px solid var(--line-dark);
      border-radius:26px;
      padding:12px;
      box-shadow:var(--shadow);
      z-index:1000;
    }

    #siteNav ul{list-style:none;margin:0;padding:0;}
    #siteNav.open ul{display:grid;gap:6px;}

    #siteNav.open a{
      width:100%;
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding:14px 16px;
      border-radius:18px;
      background:var(--white);
      color:var(--ink);
      border:1px solid var(--line);
      font-weight:800;
      text-decoration:none;
    }

    #siteNav.open a:hover{background:var(--accent-soft);}

    .nav-actions{
      display:flex;
      align-items:center;
      gap:10px;
      flex:0 0 auto;
      margin-left:auto;
    }

    .menu-btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      border:1px solid var(--line-dark);
      background:var(--white);
      color:var(--accent);
      border-radius:999px;
      padding:13px 22px;
      font-weight:800;
      cursor:pointer;
      min-height:48px;
      font-size:1rem;
      font-family:var(--font-main);
    }

    .btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:8px;
      border-radius:999px;
      padding:13px 20px;
      font-weight:800;
      text-decoration:none;
      cursor:pointer;
      line-height:1;
      transition:transform .18s ease, background .18s ease, border-color .18s ease;
      white-space:nowrap;
      border:1px solid transparent;
      font-size:.96rem;
      text-align:center;
      font-family:var(--font-main);
    }

    .btn:hover{transform:translateY(-1px);}

    .btn-primary{
      background:var(--accent);
      color:var(--accent-contrast);
      border-color:var(--accent);
      box-shadow:0 16px 38px color-mix(in srgb, var(--accent) 22%, transparent);
    }

    .btn-primary:hover{background:var(--accent-2);border-color:var(--accent-2);}

    .btn-secondary{
      background:rgba(255,255,255,.82);
      color:var(--accent);
      border-color:var(--line-dark);
    }

    .btn-secondary:hover{background:#fff;color:#13211c;}

    .btn-gold{
      background:linear-gradient(135deg, var(--gold), var(--gold-2));
      color:#17120a;
      border-color:color-mix(in srgb, var(--gold) 55%, transparent);
      box-shadow:0 16px 38px color-mix(in srgb, var(--gold) 22%, transparent);
    }

    main{overflow:hidden;}

    section{
      padding:88px 18px;
      scroll-margin-top:120px;
    }

    .wrap{max-width:var(--max);margin:auto;}

    .eyebrow{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:8px 13px;
      background:color-mix(in srgb, var(--gold) 14%, transparent);
      color:color-mix(in srgb, var(--gold) 70%, #2b1b08);
      border:1px solid color-mix(in srgb, var(--gold) 30%, transparent);
      border-radius:999px;
      font-weight:800;
      font-size:.86rem;
      margin-bottom:18px;
      max-width:100%;
    }

    h1,h2,h3{
      font-family:var(--font-heading);
      margin:0;
      line-height:1.04;
      letter-spacing:-.03em;
      color:var(--ink);
      font-weight:850;
    }

    h1{font-size:clamp(2.7rem, 6vw, 6.1rem);max-width:960px;font-weight:900;}
    h2{font-size:clamp(2rem, 4.2vw, 3.55rem);max-width:900px;}
    h3{font-size:1.32rem;letter-spacing:-.02em;}

    p{margin:0;color:var(--muted);font-weight:600;}
    strong{font-weight:800;}

    .lead{
      font-size:clamp(1.08rem, 1.6vw, 1.28rem);
      margin-top:22px;
      max-width:780px;
      color:var(--muted);
      font-weight:600;
    }

    .hero{padding:72px 18px 80px;}

    .hero-grid{
      max-width:var(--max);
      margin:auto;
      display:grid;
      grid-template-columns:1.04fr .96fr;
      gap:44px;
      align-items:center;
    }

    .hero-actions{display:flex;gap:12px;flex-wrap:wrap;margin-top:32px;}

    .trust-row{
      display:grid;
      grid-template-columns:repeat(3, 1fr);
      gap:12px;
      margin-top:32px;
      max-width:830px;
    }

    .trust-pill{
      background:rgba(255,255,255,.78);
      border:1px solid rgba(200,185,164,.78);
      border-radius:22px;
      padding:17px;
      box-shadow:var(--shadow-soft);
      backdrop-filter:blur(14px);
    }

    .trust-pill strong{display:block;font-size:1.12rem;color:var(--ink);line-height:1.2;font-weight:800;}
    .trust-pill span{display:block;color:var(--muted);font-size:.93rem;margin-top:5px;font-weight:600;}

    .hero-visual{position:relative;min-height:590px;}

    .hero-card{
      background:var(--white);
      border:1px solid rgba(200,185,164,.8);
      border-radius:40px;
      padding:12px;
      box-shadow:var(--shadow);
      position:relative;
      z-index:2;
    }

    .hero-photo{
      min-height:540px;
      border-radius:30px;
      background:
        linear-gradient(180deg, rgba(0,0,0,.02), rgba(0,0,0,.34)),
        url("https://images.unsplash.com/photo-1497366754035-f200968a6e72?auto=format&fit=crop&w=1600&q=82") center/cover;
      position:relative;
      overflow:hidden;
    }

    .photo-caption,
    .image-panel-text,
    .slide-label,
    .image-note{
      background:rgba(255,250,243,.90) !important;
      border:1px solid rgba(255,255,255,.92) !important;
      box-shadow:0 18px 38px rgba(0,0,0,.14);
      backdrop-filter:blur(14px) !important;
      -webkit-backdrop-filter:blur(14px) !important;
    }

    .photo-caption{position:absolute;left:22px;right:22px;bottom:22px;border-radius:26px;padding:22px;}

    .photo-caption strong,
    .image-panel-text strong,
    .slide-label strong,
    .image-note strong{display:block;color:#10201a !important;font-weight:800 !important;}

    .photo-caption span,
    .image-panel-text span,
    .slide-label span,
    .image-note span{display:block;color:#173128 !important;margin-top:6px;font-weight:700 !important;}

    .floating-card{
      position:absolute;
      left:-22px;
      top:42px;
      z-index:3;
      width:min(280px, 72%);
      background:rgba(255,250,243,.90);
      border:1px solid rgba(200,185,164,.85);
      border-radius:26px;
      padding:20px;
      box-shadow:var(--shadow-soft);
      backdrop-filter:blur(12px);
      -webkit-backdrop-filter:blur(12px);
    }

    .floating-card strong{display:block;font-size:2.2rem;line-height:.95;letter-spacing:-.04em;color:var(--accent);font-weight:850;}
    .floating-card span{display:block;color:#10201a;margin-top:9px;font-weight:700;line-height:1.35;}

    .mini-photo{
      position:absolute;
      right:24px;
      top:24px;
      width:220px;
      height:155px;
      border-radius:28px;
      border:8px solid rgba(255,250,243,.88);
      box-shadow:var(--shadow);
      z-index:4;
      background:url("https://images.unsplash.com/photo-1518005020951-eccb494ad742?auto=format&fit=crop&w=900&q=82") center/cover;
    }

    .section-head{
      display:flex;
      align-items:end;
      justify-content:space-between;
      gap:28px;
      margin-bottom:36px;
    }

    .section-head p{max-width:560px;font-size:1.06rem;color:var(--muted);font-weight:600;}

    .quickfacts,
    .material-section,
    .editorial,
    .methods,
    .faq-section{
      background:var(--paper);
      border-top:1px solid var(--line);
      border-bottom:1px solid var(--line);
    }

    .dashboard{display:grid;grid-template-columns:.72fr 1.28fr;gap:28px;align-items:start;}
    .split{display:grid;grid-template-columns:.92fr 1.08fr;gap:30px;align-items:start;}
    .material-grid{display:grid;grid-template-columns:.95fr 1.05fr;gap:30px;align-items:start;}
    .text-image-grid{display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:center;}

    .quick-card,
    .panel,
    .material-card,
    .method-card,
    .info-card,
    .faq-item,
    .mini-box{
      background:var(--white);
      border:1px solid var(--line-dark);
      border-radius:36px;
      padding:34px;
      box-shadow:var(--shadow-soft);
    }

    .quick-card p,
    .panel p,
    .material-card p,
    .method-card p,
    .info-card p{margin-top:14px;font-weight:600;}

    .sidebar-stack{display:grid;gap:16px;position:sticky;top:120px;}
    .mini-box{border-radius:26px;padding:22px;}
    .mini-box h3{font-size:1.2rem;}
    .mini-box a{display:block;margin-top:10px;color:var(--accent);font-weight:800;text-decoration:none;}

    .badge-list{display:flex;flex-wrap:wrap;gap:8px;margin-top:18px;}

    .badge{
      display:inline-flex;
      align-items:center;
      gap:7px;
      border-radius:999px;
      padding:8px 12px;
      background:var(--accent-soft);
      color:var(--accent);
      font-weight:800;
      font-size:.9rem;
      border:1px solid var(--line-dark);
    }

    .facts{display:grid;gap:12px;}

    .fact{
      display:grid;
      grid-template-columns:minmax(140px, .9fr) minmax(0, 1.5fr);
      gap:16px;
      align-items:center;
      background:var(--white);
      border:1px solid var(--line-dark);
      border-radius:22px;
      padding:18px;
      box-shadow:var(--shadow-soft);
      min-width:0;
    }

    .fact span{color:var(--muted);font-weight:650;min-width:0;}
    .fact strong{color:var(--ink);font-weight:800;text-align:right;min-width:0;}

    .cards,
    .method-grid{
      display:grid;
      grid-template-columns:repeat(3, 1fr);
      gap:18px;
    }

    .cards{margin-top:0;}
    .method-grid{margin-top:28px;}

    .card{
      background:rgba(255,255,255,.82);
      border:1px solid rgba(200,185,164,.8);
      border-radius:var(--radius);
      padding:27px;
      box-shadow:var(--shadow-soft);
      backdrop-filter:blur(12px);
    }

    .card-icon{
      width:50px;
      height:50px;
      border-radius:18px;
      background:var(--accent-soft);
      color:var(--accent);
      display:grid;
      place-items:center;
      font-size:1.35rem;
      margin-bottom:17px;
    }

    .card p{margin-top:10px;color:var(--muted);font-weight:600;}

    .material-list,
    .check-list{
      list-style:none;
      margin:0;
      padding:0;
      display:grid;
      gap:12px;
    }

    .material-list li{
      background:var(--paper);
      border:1px solid var(--line);
      border-radius:18px;
      padding:15px 16px;
      color:var(--muted);
      font-weight:600;
    }

    .material-list strong{color:var(--ink);font-weight:800;}

    .check-list li{
      background:var(--white);
      border:1px solid var(--line-dark);
      border-radius:22px;
      padding:19px 20px 19px 56px;
      position:relative;
      color:var(--muted);
      box-shadow:var(--shadow-soft);
      font-weight:600;
    }

    .check-list li::before{
      content:"✓";
      position:absolute;
      left:18px;
      top:19px;
      width:27px;
      height:27px;
      border-radius:999px;
      background:linear-gradient(135deg, var(--accent), var(--accent-2));
      color:var(--accent-contrast);
      display:grid;
      place-items:center;
      font-weight:800;
    }

    .check-list strong{color:var(--ink);font-weight:800;}

    .process{
      display:grid;
      grid-template-columns:repeat(4, 1fr);
      gap:16px;
      counter-reset:process;
      margin-top:30px;
    }

    .process-step{
      counter-increment:process;
      background:var(--white);
      border:1px solid var(--line-dark);
      border-radius:26px;
      padding:24px;
      box-shadow:var(--shadow-soft);
      position:relative;
    }

    .process-step::before{
      content:counter(process);
      width:38px;
      height:38px;
      border-radius:14px;
      background:linear-gradient(135deg, var(--accent), var(--accent-2));
      color:var(--accent-contrast);
      display:grid;
      place-items:center;
      font-weight:800;
      margin-bottom:16px;
    }

    .process-step h3{font-size:1.18rem;}
    .process-step p{margin-top:9px;font-weight:600;}

    .image-panel,
    .rounded-image{
      min-height:430px;
      border-radius:36px;
      overflow:hidden;
      border:1px solid var(--line-dark);
      box-shadow:var(--shadow-soft);
      position:relative;
      background-size:cover;
      background-position:center;
    }

    .image-panel{
      background:
        linear-gradient(180deg, rgba(0,0,0,.05), rgba(0,0,0,.28)),
        url("https://images.unsplash.com/photo-1497366811353-6870744d04b2?auto=format&fit=crop&w=1400&q=82") center/cover;
    }

    .image-panel-text,
    .image-note{position:absolute;left:22px;right:22px;bottom:22px;border-radius:24px;padding:20px;}

    .image-strip-wrap{margin-top:34px;}

    .drag-hint{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
      margin-bottom:14px;
      color:var(--muted);
      font-weight:650;
      font-size:.96rem;
      flex-wrap:wrap;
    }

    .gallery-tools{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}

    .gallery-arrow{
      width:48px;
      height:48px;
      border:none;
      border-radius:999px;
      background:var(--accent);
      color:var(--accent-contrast);
      cursor:pointer;
      display:grid;
      place-items:center;
      font-size:1.3rem;
      font-weight:800;
      box-shadow:0 12px 26px color-mix(in srgb, var(--accent) 22%, transparent);
      transition:.18s ease;
      flex:0 0 auto;
    }

    .gallery-arrow:hover{transform:translateY(-1px);background:var(--accent-2);}
    .gallery-arrow:disabled{opacity:.45;cursor:not-allowed;transform:none;}

    .image-strip{
      display:flex;
      gap:18px;
      overflow-x:auto;
      padding:6px 2px 10px;
      scroll-snap-type:x mandatory;
      -webkit-overflow-scrolling:touch;
      cursor:grab;
      scrollbar-width:thin;
      scrollbar-color:#9aa69f transparent;
      scroll-behavior:smooth;
    }

    .image-strip:active{cursor:grabbing;}
    .image-strip::-webkit-scrollbar{height:10px;}
    .image-strip::-webkit-scrollbar-track{background:transparent;}
    .image-strip::-webkit-scrollbar-thumb{background:color-mix(in srgb, var(--accent) 28%, transparent);border-radius:999px;}

    .photo-slide{
      flex:0 0 min(360px, 82vw);
      min-height:255px;
      border-radius:28px;
      overflow:hidden;
      border:1px solid var(--line-dark);
      box-shadow:var(--shadow-soft);
      position:relative;
      scroll-snap-align:start;
      background-size:cover;
      background-position:center;
    }

    .slide-label{position:absolute;left:16px;right:16px;bottom:16px;border-radius:18px;padding:14px 15px;}

    .text-image{background:var(--bg-2);}

    .quality-wrap{
      background:linear-gradient(135deg, var(--accent), var(--accent-2));
      color:var(--accent-contrast);
      border-radius:44px;
      padding:48px;
      box-shadow:var(--shadow);
      border:1px solid rgba(255,255,255,.18);
      position:relative;
      overflow:hidden;
    }

    .quality-wrap::before{
      content:"";
      position:absolute;
      right:-160px;
      top:-160px;
      width:360px;
      height:360px;
      border-radius:999px;
      background:color-mix(in srgb, var(--gold) 18%, transparent);
    }

    .quality-grid{display:grid;grid-template-columns:.88fr 1.12fr;gap:34px;align-items:center;position:relative;z-index:2;}

    .score{
      background:rgba(255,255,255,.12);
      border:1px solid rgba(255,255,255,.24);
      border-radius:34px;
      padding:34px;
      backdrop-filter:blur(12px);
    }

    .score strong{display:block;font-size:clamp(3.8rem, 8vw, 7.1rem);line-height:.85;letter-spacing:-.05em;color:var(--accent-contrast);font-weight:850;}
    .score span{display:block;margin-top:16px;color:var(--accent-contrast);font-weight:700;opacity:.9;}

    .quality-wrap .eyebrow{background:rgba(255,255,255,.12);color:var(--accent-contrast);border-color:rgba(255,255,255,.28);}
    .quality-wrap h2,.quality-wrap p{color:var(--accent-contrast);}
    .quality-wrap p{margin-top:16px;font-size:1.08rem;font-weight:600;opacity:.92;}

    .steps{counter-reset:step;display:grid;gap:16px;}

    .step{
      counter-increment:step;
      background:var(--white);
      border:1px solid var(--line-dark);
      border-radius:26px;
      padding:24px 24px 24px 82px;
      position:relative;
      box-shadow:var(--shadow-soft);
    }

    .step::before{
      content:counter(step);
      position:absolute;
      left:24px;
      top:24px;
      width:42px;
      height:42px;
      border-radius:15px;
      background:linear-gradient(135deg, var(--accent), var(--accent-2));
      color:var(--accent-contrast);
      display:grid;
      place-items:center;
      font-weight:800;
    }

    .step p{margin-top:7px;color:var(--muted);font-weight:600;}

    .faq-grid{display:grid;grid-template-columns:repeat(2, 1fr);gap:16px;margin-top:28px;}
    .faq-item{border-radius:26px;padding:24px;}
    .faq-item h3{font-size:1.18rem;}
    .faq-item p{margin-top:9px;font-weight:600;}

    .contact{
      background:var(--contact-bg);
      color:#fff;
      border-top:1px solid rgba(255,255,255,.10);
    }

    .contact h2,.contact h3,.contact p{color:#fff;}
    .contact .eyebrow{background:rgba(255,255,255,.10);color:#fff;border-color:rgba(255,255,255,.25);}

    .contact-grid{display:grid;grid-template-columns:.82fr 1.18fr;gap:28px;align-items:start;}

    .contact-box,
    form{
      background:var(--paper);

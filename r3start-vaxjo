  <script>
    const body = document.body;
    const langButtons = document.querySelectorAll("[data-set-lang]");
    const menuBtn = document.getElementById("menuBtn");
    const siteNav = document.getElementById("siteNav");
    const contrastToggle = document.getElementById("contrastToggle");
    const readPage = document.getElementById("readPage");

    function setLanguage(lang){
      body.classList.toggle("lang-en", lang === "en");
      document.documentElement.lang = lang;

      langButtons.forEach(btn => {
        btn.classList.toggle("active", btn.dataset.setLang === lang);
        btn.setAttribute("aria-pressed", btn.dataset.setLang === lang ? "true" : "false");
      });

      const message = document.getElementById("message");
      if(message){
        message.placeholder = lang === "en"
          ? "Briefly describe what the inquiry is about..."
          : "Skriv kort vad ärendet gäller...";
      }
    }

    langButtons.forEach(btn => {
      btn.addEventListener("click", () => setLanguage(btn.dataset.setLang));
    });

    if(menuBtn && siteNav){
      menuBtn.addEventListener("click", () => {
        const isOpen = siteNav.classList.toggle("open");
        menuBtn.setAttribute("aria-expanded", isOpen ? "true" : "false");
      });

      siteNav.querySelectorAll("a").forEach(link => {
        link.addEventListener("click", () => {
          siteNav.classList.remove("open");
          menuBtn.setAttribute("aria-expanded", "false");
        });
      });
    }

    if(contrastToggle){
      contrastToggle.addEventListener("click", () => {
        body.classList.toggle("high-contrast");
        contrastToggle.setAttribute("aria-pressed", body.classList.contains("high-contrast") ? "true" : "false");
      });
    }

    if(readPage){
      readPage.addEventListener("click", () => {
        if(!("speechSynthesis" in window)){
          alert("Din webbläsare stödjer inte uppläsning.");
          return;
        }

        if(window.speechSynthesis.speaking){
          window.speechSynthesis.cancel();
          readPage.textContent = document.documentElement.lang === "en" ? "Read aloud" : "Läs upp";
          return;
        }

        const lang = document.documentElement.lang || "sv";
        const visibleText = Array
          .from(document.querySelectorAll("main h1, main h2, main h3, main p, main li"))
          .filter(el => {
            const style = window.getComputedStyle(el);
            return style.display !== "none" && style.visibility !== "hidden";
          })
          .map(el => el.innerText.trim())
          .filter(Boolean)
          .join(". ");

        const utterance = new SpeechSynthesisUtterance(visibleText);
        utterance.lang = lang === "en" ? "en-US" : "sv-SE";
        utterance.rate = 0.92;

        utterance.onend = () => {
          readPage.textContent = document.documentElement.lang === "en" ? "Read aloud" : "Läs upp";
        };

        readPage.textContent = lang === "en" ? "Stop reading" : "Stoppa uppläsning";
        window.speechSynthesis.speak(utterance);
      });
    }

    document.querySelector("form").addEventListener("submit", function(event){
      event.preventDefault();
      const lang = document.documentElement.lang;
      alert(lang === "en"
        ? "Demo form. In the finished version, this sends the inquiry."
        : "Demoformulär. I färdig version skickas förfrågan vidare.");
    });
  </script>
